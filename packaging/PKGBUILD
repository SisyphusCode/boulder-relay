# Maintainer: SisyphusAeolides
pkgname=boulder-relay
pkgver=0.5.0
pkgrel=1
pkgdesc="A fast, clean GTK4 + libadwaita IRC client written in Rust"
arch=('x86_64' 'aarch64')
url="https://github.com/SisyphusAeolides/boulder-relay"
license=('GPL-2.0-or-later')
depends=('gtk4' 'libadwaita' 'openssl')
makedepends=('cargo' 'rust' 'git')
source=("$pkgname-$pkgver.tar.gz::https://github.com/SisyphusAeolides/boulder-relay/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
    cd "$pkgname-$pkgver"
    cargo fetch --locked
    cargo build --release --no-deps
}

package() {
    cd "$pkgname-$pkgver"
    
    # Install binary
    install -Dm755 "target/release/$pkgname" -t "$pkgdir/usr/bin"
    
    # Install desktop file
    install -Dm644 "packaging/boulder-relay.desktop" -t "$pkgdir/usr/share/applications"
    
    # Install icons
    install -Dm644 "assets/boulder-relay-128.png" "$pkgdir/usr/share/icons/hicolor/128x128/apps/$pkgname.png"
    install -Dm644 "assets/boulder-relay-256.png" "$pkgdir/usr/share/icons/hicolor/256x256/apps/$pkgname.png"
    
    # Install appstream metadata
    install -Dm644 "packaging/org.Sisyphus.BoulderRelay.metainfo.xml" -t "$pkgdir/usr/share/metainfo"
    
    # Install license
    install -Dm644 "LICENSE" -t "$pkgdir/usr/share/licenses/$pkgname"
}

# vim:set ts=2 sw=2 et: